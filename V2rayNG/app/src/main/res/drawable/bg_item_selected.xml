<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom/Right Selected Shadow (Dark Green) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/apple_dark_green" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Top/Left Selected Highlight (Vibrant Green) -->
    <item
        android:bottom="1.5dp"
        android:right="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/apple_green" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Main Selected Content Background -->
    <item
        android:top="1.5dp"
        android:left="1.5dp"
        android:bottom="2.5dp"
        android:right="2.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/apple_card_bg_selected" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
