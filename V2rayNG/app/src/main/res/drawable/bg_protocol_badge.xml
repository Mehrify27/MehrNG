<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom/Right Highlight (Light) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_stroke_top_highlight" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Top/Left Shadow (Dark) -->
    <item
        android:bottom="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_stroke_bottom_shadow" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Content Background (Recessed) -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:bottom="1.5dp"
        android:right="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/protocol_badge_bg" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</layer-list>
